{
  "name": "deploykit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @deploykit/api dev",
    "dev:web": "pnpm --filter @deploykit/web dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @deploykit/api db:generate",
    "db:migrate": "pnpm --filter @deploykit/api db:migrate",
    "db:studio": "pnpm --filter @deploykit/api db:studio",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}

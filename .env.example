# ══════════════════════════════════════════════════════════════
#  DeployKit — Development Environment
#  Copy this file to .env and fill in the values.
#
#  Generate secrets:
#    openssl rand -hex 32    (for ENCRYPTION_KEY — 64 hex chars)
#    openssl rand -base64 32 (for JWT secrets)
# ══════════════════════════════════════════════════════════════

# Domain & SSL (production only)
# DOMAIN=panel.yourdomain.com
# ACME_EMAIL=your@email.com

# Database (PostgreSQL)
DB_USER=deploykit
DB_PASSWORD=deploykit_dev
DB_NAME=deploykit
DATABASE_URL=postgresql://deploykit:deploykit_dev@localhost:5432/deploykit

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
# Generate each with: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# Encryption
# Used to encrypt env vars, source tokens, and SSH keys at rest.
# Must be a 64-character hex string. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Webhooks
# HMAC secret for verifying GitHub/GitLab webhook signatures.
# Generate with: openssl rand -base64 32
WEBHOOK_SECRET=

# Ports
API_PORT=3001
WEB_PORT=5173

# CORS
# In production this must match the public URL of your dashboard.
WEB_URL=http://localhost:5173

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Admin Account (optional)
# Pre-create an admin account on first run.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=

# Audit Logs
# Number of days to retain audit log entries (default: 90)
AUDIT_RETENTION_DAYS=90

# Docker (advanced)
# Override the Docker socket path. Auto-detected on most systems.
# DOCKER_SOCKET=/var/run/docker.sock
